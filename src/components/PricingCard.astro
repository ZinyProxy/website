---
import Button from './Button.astro';
import { DASHBOARD } from '../config';
interface Props {
  name: string;
  price: string;
  unit?: string;
  blurb?: string;
  features: string[];
  featured?: boolean;
}
const { name, price, unit = '/GB', blurb, features, featured = false } = Astro.props;
---
<div
  class:list={[
    'flex flex-col rounded-2xl border p-7 transition-transform',
    featured
      ? 'border-brand bg-ink-850 shadow-[0_0_0_1px] shadow-brand/40 lg:-translate-y-2'
      : 'border-white/10 bg-ink-850',
  ]}
>
  {featured && (
    <span class="mb-4 inline-block w-fit rounded-full bg-brand px-3 py-1 font-body text-xs font-medium text-white">
      Most Popular
    </span>
  )}
  <h3 class="font-heading text-xl font-semibold text-white">{name}</h3>
  {blurb && <p class="mt-1 font-body text-sm text-white/55">{blurb}</p>}
  <div class="mt-5 flex items-baseline gap-1">
    <span class="font-heading text-4xl font-bold text-white">{price}</span>
    <span class="font-body text-sm text-white/50">{unit}</span>
  </div>
  <ul class="mt-6 flex-1 space-y-3">
    {features.map((f) => (
      <li class="flex items-start gap-2 font-body text-sm text-white/75">
        <svg class="mt-0.5 h-4 w-4 shrink-0 text-brand" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M16.7 5.3a1 1 0 0 1 0 1.4l-7.5 7.5a1 1 0 0 1-1.4 0L3.3 9.7a1 1 0 1 1 1.4-1.4l3.1 3.1 6.8-6.8a1 1 0 0 1 1.4 0Z" clip-rule="evenodd" />
        </svg>
        {f}
      </li>
    ))}
  </ul>
  <Button href={DASHBOARD.register} external variant={featured ? 'primary' : 'ghost'} class="mt-7 w-full">
    Get Started
  </Button>
</div>
