---
interface Props {
  quote: string;
  name: string;
  role?: string;
  rating?: number;
}
const { quote, name, role, rating = 5 } = Astro.props;
const stars = Array.from({ length: 5 }, (_, i) => i < rating);
---
<figure class="flex h-full flex-col rounded-2xl border border-white/10 bg-ink-850 p-6">
  <div class="flex gap-1" aria-label={`${rating} out of 5 stars`}>
    {stars.map((on) => (
      <svg class:list={['h-4 w-4', on ? 'text-accent-orange' : 'text-white/15']} viewBox="0 0 20 20" fill="currentColor">
        <path d="M10 1.5l2.6 5.3 5.9.9-4.2 4.1 1 5.8L10 15l-5.3 2.6 1-5.8L1.5 7.7l5.9-.9L10 1.5Z" />
      </svg>
    ))}
  </div>
  <blockquote class="mt-4 flex-1 font-body text-sm leading-relaxed text-white/80">“{quote}”</blockquote>
  <figcaption class="mt-5 border-t border-white/10 pt-4">
    <span class="block font-heading text-sm font-semibold text-white">{name}</span>
    {role && <span class="font-body text-xs text-white/50">{role}</span>}
  </figcaption>
</figure>
