---
/** Ziny wordmark — Z mark in brand pink + "iny" in white. */
interface Props { class?: string }
const { class: cls = '' } = Astro.props;
---
<a href="/" class:list={['inline-flex items-baseline font-heading text-2xl font-bold tracking-tight', cls]}>
  <span class="text-brand">Z</span><span class="text-white">iny</span>
</a>
