---
import Container from './Container.astro';
import Logo from './Logo.astro';
import { FOOTER } from '../config';
const year = new Date().getFullYear();
---
<footer class="border-t border-white/10 bg-ink-900">
  <Container class="py-14">
    <div class="grid gap-10 md:grid-cols-[1.4fr_repeat(4,1fr)]">
      <div>
        <Logo />
        <p class="mt-4 max-w-xs font-body text-sm text-white/55">
          Clean &amp; private proxies built for performance — residential, mobile, ISP and datacenter.
        </p>
      </div>
      {FOOTER.map((col) => (
        <div>
          <h4 class="font-heading text-sm font-semibold uppercase tracking-wider text-white">{col.title}</h4>
          <ul class="mt-4 space-y-2.5">
            {col.links.map((l) => (
              <li>
                <a href={l.href} class="font-body text-sm text-white/55 transition-colors hover:text-brand">
                  {l.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
    <div class="mt-12 border-t border-white/10 pt-6">
      <p class="font-body text-xs text-white/40">© {year} Ziny Proxy. All rights reserved.</p>
    </div>
  </Container>
</footer>
