---
/**
 * Homepage — 1:1 with live ziny.io. Markup + CSS + original scripts from a
 * live capture (scripts/build-all-pages.mjs). Scripts re-emitted as real tags
 * so Elementor's own JS runs identically (globe, dropdowns, dashboard, swiper).
 */
import { readFileSync } from 'node:fs';
const css = readFileSync('src/captured/home.styles.css', 'utf8');
const body = readFileSync('src/captured/home.body.html', 'utf8');
let bodyClass = '';
try { bodyClass = readFileSync('src/captured/home.bodyclass.txt', 'utf8'); } catch {}
let scripts: { src?: string; code?: string }[] = [];
try { scripts = JSON.parse(readFileSync('src/captured/home.scripts.json', 'utf8')); } catch {}
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Ziny Proxy | Buy Clean & Reliable Private Proxy Servers</title>
    <meta name="description" content="Ziny Proxy offers over 30 million IPs across 195 countries. Unrestricted & Unlimited residential proxy, mobile proxy, and datacenter IPs." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <style is:inline set:html={css}></style>
  </head>
  <body class={bodyClass}>
    <Fragment set:html={body} />
    {scripts.map((s) => (s.src
      ? <script is:inline src={s.src}></script>
      : <script is:inline set:html={s.code}></script>))}
  </body>
</html>
