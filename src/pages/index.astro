---
/**
 * Homepage — pixel-identical to the live ziny.io.
 * Markup + CSS come straight from a live capture (see scripts/build-home.mjs).
 * Re-run `node scripts/build-home.mjs` whenever ziny.io changes.
 * Motion (globe / carousels) lives in lightweight modules added separately.
 */
import { readFileSync } from 'node:fs';
const css = readFileSync('src/captured/home.styles.css', 'utf8');
const body = readFileSync('src/captured/home.body.html', 'utf8');
let bodyClass = '';
try { bodyClass = readFileSync('src/captured/home.bodyclass.txt', 'utf8'); } catch {}
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Ziny — Clean &amp; Private Proxies, #1 Performance</title>
    <meta name="description" content="Residential, mobile, ISP and datacenter proxies engineered for the highest success rates." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <style is:inline set:html={css}></style>
    <script>
      import '../scripts/interactions.ts';
    </script>
  </head>
  <body class={bodyClass} set:html={body}></body>
</html>
