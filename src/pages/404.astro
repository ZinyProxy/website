---
/**
 * Renders the captured ziny.io 404 page.
 * Source: src/captured/__404.{body.html, head.html, styles.css, ...}
 * Astro outputs this as dist/404.html, which the host (cPanel/Apache via
 * .htaccess `ErrorDocument 404 /404.html`) serves on any missing URL.
 */
import { readFileSync } from 'node:fs';
import { join } from 'node:path';

const file = '__404';
const body = readFileSync(join('src/captured', `${file}.body.html`), 'utf8');
const css = readFileSync(join('src/captured', `${file}.styles.css`), 'utf8');
let bodyClass = '';
try { bodyClass = readFileSync(join('src/captured', `${file}.bodyclass.txt`), 'utf8'); } catch {}
let scripts: { src?: string; code?: string }[] = [];
try { scripts = JSON.parse(readFileSync(join('src/captured', `${file}.scripts.json`), 'utf8')); } catch {}
let cssLinks: string[] = [];
try { cssLinks = JSON.parse(readFileSync(join('src/captured', `${file}.links.json`), 'utf8')); } catch {}

let headRaw = '';
try { headRaw = readFileSync(join('src/captured', `${file}.head.html`), 'utf8'); } catch {}
const head = headRaw
  .replace(/<link[^>]+rel=['"]stylesheet['"][^>]*>/gi, '')
  .replace(/<style[\s\S]*?<\/style>/gi, '');

let lang = 'en';
try {
  const attrs = JSON.parse(readFileSync(join('src/captured', `${file}.html-attrs.json`), 'utf8'));
  if (attrs.lang) lang = attrs.lang;
} catch {}
---
<!doctype html>
<html lang={lang}>
  <head>
    <Fragment set:html={head} />
    {cssLinks.map((href) => <link rel="stylesheet" href={href} />)}
    <style is:inline set:html={css}></style>
    <link rel="sitemap" href="/sitemap-index.xml" />
  </head>
  <body class={bodyClass}>
    <Fragment set:html={body} />
    {scripts.map((s) => (s.src
      ? <script is:inline src={s.src}></script>
      : <script is:inline set:html={s.code}></script>))}
  </body>
</html>
