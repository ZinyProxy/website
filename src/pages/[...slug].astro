---
/**
 * Renders every captured ziny.io page at its original URL.
 * Source: src/captured/<slug>.{body.html, styles.css, bodyclass.txt, scripts.json}
 * (produced by scripts/build-all-pages.mjs from the live site).
 *
 * Scripts are re-emitted as real, executing <script> tags so Elementor's own
 * JS (nested menu/tabs, swiper, sticky, the D3 globe, dashboard motion) runs
 * exactly like the live site. Trailing slashes preserved by astro.config.
 */
import { readFileSync, readdirSync } from 'node:fs';
import { join } from 'node:path';

export async function getStaticPaths() {
  const dir = 'src/captured';
  const slugs = readdirSync(dir)
    .filter((f) => f.endsWith('.body.html'))
    .map((f) => f.replace(/\.body\.html$/, ''))
    .filter((s) => s !== 'home') // root is served by src/pages/index.astro
    .filter((s) => !s.startsWith('__')); // __404 etc. served by their own src/pages/ template

  return slugs.map((slug) => ({
    params: { slug: slug.replace(/__/g, '/') },
  }));
}

const { slug } = Astro.params;
const file = slug.replace(/\//g, '__');
const body = readFileSync(join('src/captured', `${file}.body.html`), 'utf8');
const css = readFileSync(join('src/captured', `${file}.styles.css`), 'utf8');
let bodyClass = '';
try { bodyClass = readFileSync(join('src/captured', `${file}.bodyclass.txt`), 'utf8'); } catch {}
let scripts: { src?: string; code?: string }[] = [];
try { scripts = JSON.parse(readFileSync(join('src/captured', `${file}.scripts.json`), 'utf8')); } catch {}
let cssLinks: string[] = [];
try { cssLinks = JSON.parse(readFileSync(join('src/captured', `${file}.links.json`), 'utf8')); } catch {}

// Captured raw <head> from the live page — full Yoast SEO (title, description,
// canonical, robots, OG, Twitter, schema.org JSON-LD). Strip stylesheets and
// inline <style> blocks since we re-inject the locally-mirrored CSS below.
let headRaw = '';
try { headRaw = readFileSync(join('src/captured', `${file}.head.html`), 'utf8'); } catch {}
const head = headRaw
  .replace(/<link[^>]+rel=['"]stylesheet['"][^>]*>/gi, '')
  .replace(/<style[\s\S]*?<\/style>/gi, '');

let lang = 'en';
try {
  const attrs = JSON.parse(readFileSync(join('src/captured', `${file}.html-attrs.json`), 'utf8'));
  if (attrs.lang) lang = attrs.lang;
} catch {}

// Perf: identify the LCP image candidate to preload. The first <img> in the
// captured body is usually the hero/logo (already fetchpriority="high" from WP).
// Preloading it cuts ~500ms off mobile LCP per Lighthouse.
const lcpMatch = body.match(/<img[^>]+src="([^"]+)"[^>]*>/i);
const lcpImage = lcpMatch?.[1] ?? null;

// Perf: split external CSS into critical (block render) vs non-critical
// (async load via media-print trick). Core layout/theme/header CSS is
// critical so above-fold renders correctly; widget-specific CSS can swap in
// progressively without blocking. Cuts mobile render-blocking time
// ~1500ms per Lighthouse.
const CRITICAL_CSS = /reset|theme|header_footer|frontend\.min\.css|widget_image|widget_heading|widget_text_editor/i;
const criticalCss = cssLinks.filter((h) => CRITICAL_CSS.test(h));
const deferredCss = cssLinks.filter((h) => !CRITICAL_CSS.test(h));

// Perf: identify 3rd-party scripts (Tawk, gtag, analytics) to defer until
// the page is interactive, so they don't compete with critical resources
// for the main thread during the LCP window.
const isThirdParty = (s: { src?: string; code?: string }) => {
  if (s.src && /tawk|googletagmanager|google-analytics|googleadservices|doubleclick|facebook\.net|hotjar|clarity|iconify|cdnjs|jsdelivr/i.test(s.src)) return true;
  if (s.code && /Tawk_API|gtag\(|fbq\(|googletag/i.test(s.code)) return true;
  return false;
};
const criticalScripts = scripts.filter((s) => !isThirdParty(s));
const deferredScripts = scripts.filter((s) => isThirdParty(s));
---
<!doctype html>
<html lang={lang}>
  <head>
    <Fragment set:html={head} />
    {lcpImage && <link rel="preload" as="image" href={lcpImage} fetchpriority="high" />}
    {criticalCss.map((href) => <link rel="stylesheet" href={href} />)}
    {deferredCss.map((href) => (
      <link rel="preload" as="style" href={href} onload="this.onload=null;this.rel='stylesheet'" />
    ))}
    <noscript>{deferredCss.map((href) => <link rel="stylesheet" href={href} />)}</noscript>
    <style is:inline set:html={css}></style>
    <link rel="sitemap" href="/sitemap-index.xml" />
  </head>
  <body class={bodyClass}>
    <Fragment set:html={body} />
    {criticalScripts.map((s) => (s.src
      ? <script is:inline src={s.src}></script>
      : <script is:inline set:html={s.code}></script>))}
    {/* Defer 3rd-party scripts until idle so they don't compete with LCP. */}
    <script is:inline define:vars={{ deferredScripts }}>{`
      (function () {
        function load() {
          for (const s of deferredScripts) {
            const tag = document.createElement('script');
            if (s.src) tag.src = s.src;
            else tag.textContent = s.code;
            tag.async = true;
            document.body.appendChild(tag);
          }
        }
        if ('requestIdleCallback' in window) requestIdleCallback(load, { timeout: 2500 });
        else setTimeout(load, 1500);
      })();
    `}</script>
  </body>
</html>
