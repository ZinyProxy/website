---
/**
 * Renders every captured ziny.io page at its original URL.
 * Source: src/captured/<slug>.{body.html, styles.css}  (produced by
 * scripts/build-all-pages.mjs from a Playwright crawl of the live site).
 *
 * Trailing slashes are preserved by Astro's site-wide config
 * (`trailingSlash: 'always'`, `build.format: 'directory'`).
 */
import { readFileSync, readdirSync } from 'node:fs';
import { join } from 'node:path';

export async function getStaticPaths() {
  const dir = 'src/captured';
  const slugs = readdirSync(dir)
    .filter((f) => f.endsWith('.body.html'))
    .map((f) => f.replace(/\.body\.html$/, ''))
    .filter((s) => s !== 'home'); // root is served by src/pages/index.astro

  return slugs.map((slug) => ({
    // Capture script uses '__' to flatten WordPress slashes into a directory
    // name. Reverse that here so `category__guide` -> `/category/guide/`.
    params: { slug: slug.replace(/__/g, '/') },
  }));
}

const { slug } = Astro.params;
const file = slug.replace(/\//g, '__');
const body = readFileSync(join('src/captured', `${file}.body.html`), 'utf8');
const css = readFileSync(join('src/captured', `${file}.styles.css`), 'utf8');
let bodyClass = '';
try { bodyClass = readFileSync(join('src/captured', `${file}.bodyclass.txt`), 'utf8'); } catch {}

// Real title/description from the Playwright crawl meta (falls back gracefully).
let title = `${slug} | Ziny.io`, description = '';
try {
  const meta = JSON.parse(readFileSync(join('reference/pages', file, 'meta.json'), 'utf8'));
  if (meta.title) title = meta.title;
  if (meta.description) description = meta.description;
} catch {}
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <style is:inline set:html={css}></style>
    <script>
      // Restores globe spin, carousels, tabs, accordion, mobile menu, sticky
      // header, and Tawk.to chatbot on the captured Elementor markup.
      import '../scripts/interactions.ts';
    </script>
    <!-- Prism syntax highlighting + clipboard + iconify (same as live ziny.io) -->
    <script is:inline defer src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.23.0/components/prism-core.min.js"></script>
    <script is:inline defer src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.23.0/plugins/autoloader/prism-autoloader.min.js"></script>
    <script is:inline defer src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.23.0/plugins/line-numbers/prism-line-numbers.min.js"></script>
    <script is:inline defer src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.23.0/plugins/normalize-whitespace/prism-normalize-whitespace.min.js"></script>
    <script is:inline defer src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.23.0/plugins/toolbar/prism-toolbar.min.js"></script>
    <script is:inline defer src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.23.0/plugins/copy-to-clipboard/prism-copy-to-clipboard.min.js"></script>
    <script is:inline defer src="https://cdnjs.cloudflare.com/ajax/libs/clipboard.js/2.0.0/clipboard.min.js"></script>
    <script is:inline defer src="https://code.iconify.design/3/3.1.0/iconify.min.js"></script>
  </head>
  <body class={bodyClass} set:html={body}></body>
</html>
