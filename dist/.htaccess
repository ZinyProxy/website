# --- Ziny static site: compression + caching (Apache/cPanel) ---

# Serve the captured 1:1 clone of the live ziny.io 404 page on any missing URL.
ErrorDocument 404 /404.html

# --- 301 redirects (link-audit findings, see reference/link-audit.json) ---
# Use RedirectMatch with end-anchors so we don't accidentally redirect URLs
# that *start with* the same prefix (Apache's `Redirect` matches by prefix).
<IfModule mod_alias.c>
  # Match live ziny.io's 301: /pricing[/] → /pricing-for-testing-purposes/
  RedirectMatch 301 ^/pricing/?$ /pricing-for-testing-purposes/

  # Fix WP content typos that produce 404s in-page (38+14+14+... bad in-page links).
  # NOTE: live ziny.io also 404s these — fixing them on our build is a *deliberate*
  # divergence from live, to improve UX. Approved by Val 2026-05-27.
  RedirectMatch 301 ^/social-media-proxy/?$ /social-media-managment/
  RedirectMatch 301 ^/market-monitoring/?$ /market-research/
  RedirectMatch 301 ^/ecommerce-proxis/?$ /ecommerce-proxies/
  RedirectMatch 301 ^/tinder-proxies/?$ /tinder-proxy/
  RedirectMatch 301 ^/youyube-proxies/?$ /youtube-proxies/
  RedirectMatch 301 ^/residential-proxies/?$ /residential-proxy/
  RedirectMatch 301 ^/roblox-proxy/?$ /unblock-roblox/
  RedirectMatch 301 ^/what-is-browserscan/?$ /browserscan-guide/
  RedirectMatch 301 ^/pirate-bay-proxy-alternatives-2026/?$ /best-pirate-bay-proxy/
  RedirectMatch 301 ^/blog/what-are-residential-proxies/?$ /what-is-a-residential-proxy/
  RedirectMatch 301 ^/use-cases/ecommerce-scraping/?$ /ecommerce-proxies/

  # Author has only 1 page of posts — collapse any phantom paginated URLs.
  RedirectMatch 301 ^/author/daniel-cole/page/\d+/?$ /author/daniel-cole/
</IfModule>


# Gzip/deflate text assets — cuts HTML/CSS/JS transfer ~10x.
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/xml
  AddOutputFilterByType DEFLATE application/javascript application/x-javascript text/javascript
  AddOutputFilterByType DEFLATE application/json application/xml application/rss+xml
  AddOutputFilterByType DEFLATE image/svg+xml application/vnd.ms-fontobject application/x-font-ttf font/ttf font/otf font/woff font/woff2
</IfModule>

# Long-cache fingerprinted/static assets; short-cache HTML.
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css                "access plus 1 year"
  ExpiresByType application/javascript  "access plus 1 year"
  ExpiresByType text/javascript         "access plus 1 year"
  ExpiresByType image/png               "access plus 1 year"
  ExpiresByType image/jpeg              "access plus 1 year"
  ExpiresByType image/webp              "access plus 1 year"
  ExpiresByType image/svg+xml           "access plus 1 year"
  ExpiresByType image/x-icon            "access plus 1 year"
  ExpiresByType font/woff2              "access plus 1 year"
  ExpiresByType font/woff               "access plus 1 year"
  ExpiresByType application/json        "access plus 1 week"
  ExpiresByType text/html               "access plus 0 seconds"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(css|js|png|jpe?g|webp|svg|ico|woff2?|ttf|otf)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # HTML must never be cached on the staging site — always serve the latest build.
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>
</IfModule>
